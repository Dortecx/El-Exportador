{
  "name": "m3u-to-ytmusic",
  "version": "1.0.0",
  "description": "Convert M3U playlists to YouTube Music",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "m3u-to-ytmusic": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli.ts",
    "web": "tsx src/web/server.ts",
    "web:dist": "node dist/web/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "dry-run": "tsx src/cli.ts test/fixtures/extended.m3u --dry-run"
  },
  "keywords": [
    "m3u",
    "youtube",
    "youtube-music",
    "playlist",
    "converter"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "express": "^4.22.1",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0"
  },
  "devDependencies": {
    "@esbuild/linux-x64": "^0.28.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
